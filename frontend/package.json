{
  "name": "icore-frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "rsbuild dev",
    "watch": "rsbuild build --watch",
    "build": "rsbuild build",
    "generate:api": "openapi-typescript openapi.json --default-non-nullable false -o src/api/generated.ts",
    "lint": "eslint --max-warnings 0 .",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run build"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.1.0"
  },
  "devDependencies": {
    "@rsbuild/core": "^1.1.0",
    "@rsbuild/plugin-react": "^1.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0"
  }
}
